# Required
GITLAB_WEBHOOK_SECRET=your-webhook-secret-token
BOT_USERNAME=agent
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_HOST=https://gitlab.com

# Optional
DEFAULT_AGENT=claude
PORT=3000
DATABASE_PATH=./data/glab-review.db
LOG_LEVEL=info
WORKER_CONCURRENCY=2
AGENT_TIMEOUT_MS=600000

# Agent CLI paths (optional, defaults to command name)
CLAUDE_PATH=claude
CODEX_PATH=codex
GEMINI_PATH=gemini
